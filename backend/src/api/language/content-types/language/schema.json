{
  "kind": "collectionType",
  "collectionName": "languages",
  "info": {
    "singularName": "language",
    "pluralName": "languages",
    "displayName": "Language"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": { "type": "string", "required": true, "unique": true },
    "isoCode": { "type": "string" },
    "ambassadors": { "type": "relation", "relation": "manyToMany", "target": "api::ambassador.ambassador", "inversedBy": "languages" },
    "countries": { "type": "relation", "relation": "manyToMany", "target": "api::country.country", "mappedBy": "languages" },
    "faqs": { "type": "relation", "relation": "oneToMany", "target": "api::faq.faq", "mappedBy": "language" },
    "studentInquiries": { "type": "relation", "relation": "oneToMany", "target": "api::student-inquiry.student-inquiry", "mappedBy": "preferredLanguage" }
  }
}
